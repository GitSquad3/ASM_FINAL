@model SIMSWebApp.Models.CourseViewModel

@{
    ViewData["Title"] = "Course Details";
    Layout = "_LayoutMain";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Course Details</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Course">Courses</a></li>
        <li class="breadcrumb-item active">Course Details</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-info-circle me-1"></i>
            Course Information
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Course Name</label>
                        <p class="form-control-plaintext">@Model.CourseName</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Course Code</label>
                        <p class="form-control-plaintext">@Model.CourseCode</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Credits</label>
                        <p class="form-control-plaintext">@Model.Credits</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Duration</label>
                        <p class="form-control-plaintext">@Model.Duration</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Department</label>
                        <p class="form-control-plaintext">@Model.Department</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Instructor</label>
                        <p class="form-control-plaintext">@Model.Instructor</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Semester</label>
                        <p class="form-control-plaintext">@Model.Semester</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Academic Year</label>
                        <p class="form-control-plaintext">@Model.AcademicYear</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Maximum Students</label>
                        <p class="form-control-plaintext">@(Model.MaxStudents?.ToString() ?? "Not specified")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Course Fee</label>
                        <p class="form-control-plaintext">@(Model.Fee?.ToString("C") ?? "Not specified")</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <p class="form-control-plaintext">@Model.Description</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Created At</label>
                        <p class="form-control-plaintext">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Last Updated</label>
                        <p class="form-control-plaintext">@(Model.UpdatedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Never updated")</p>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Status</label>
                        <p class="form-control-plaintext">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>
                    Back to List
                </a>
                <div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.CourseID" class="btn btn-primary me-2">
                            <i class="fas fa-edit me-1"></i>
                            Edit Course
                        </a>
                        <form asp-action="Delete" asp-route-id="@Model.CourseID" method="post" style="display: inline;" 
                              onsubmit="return confirm('Are you sure you want to delete this course? This action cannot be undone.');">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i>
                                Delete Course
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add any additional JavaScript functionality if needed
        });
    </script>
}
